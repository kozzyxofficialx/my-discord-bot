# Discord bot token (https://discord.com/developers/applications)
TOKEN=

# Anthropic Claude API key — required for /ask /summarize /translate /generate_rules and AI moderation
ANTHROPIC_API_KEY=

# xAI Grok API key — required for /roast (falls back to static lines if missing)
XAI_API_KEY=

# Optional: only used by deploy-guild.js for instant per-guild deploys
CLIENT_ID=
GUILD_ID=
